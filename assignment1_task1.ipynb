import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
plt.rcParams.update({'font.size': 20, 'figure.figsize': (8, 4)})

%matplotlib inline
import matplotlib_inline
matplotlib_inline.backend_inline.set_matplotlib_formats('svg')

import seaborn as sns
sns.set()

df = pd.read_csv("supermarket_sales.csv")
df.info()

# ========================================== Question1 ==========================================
### how many purchases (rows in the table, not 'Quantity') were done by Male and Female customers?
m_amount = len(df[df['Gender'] == 'Male'])
f_amount = len(df[df['Gender'] == 'Female'])

# do not print any intermediate results
# print *only your final* result in the form of a data frame (for clarity)

result_q1 = [('purchases by male', m_amount), ('purchases by female', f_amount)]
pd.DataFrame(result_q1)

# ========================================== Question2 ==========================================
### what is the average Rating for products in the "Home and lifestyle" Product line?
home_df = df[df['Product line'] == 'Home and lifestyle']
avg_rating = home_df['Rating'].mean()
result_q2 = [('Average rating for Home and lifestyle', avg_rating)]
pd.DataFrame(result_q2, columns=['description', 'value'])

# ========================================== Question3 ==========================================
### how many products in each Product line were sold during the first week (days 1-7 including) of February 2019?
### use the 'Quantity' column for that purpose - the number of products purchased

# solution idea: filter relevant dates (relevant lines) -> count per 'Product line' the sum of sold quantities.
# relevant dates (MM/DD/YYYY): 02/01/2019 , 02/02/2019 , ... , 02/07/2019.
relevant_dates = ['02/01/2019' , '02/02/2019' , '02/03/2019' , '02/04/2019' , '02/05/2019' , '02/06/2019' , '02/07/2019']
relevant_lines = df[df['Date'].isin(relevant_dates)]
relevant_lines.groupby('Product line')['Quantity'].sum()
quantity_per_product_line = relevant_lines.groupby('Product line')['Quantity'].sum()
result_q3 = quantity_per_product_line.reset_index()
result_q3.columns = ['product line', 'sum of sold products']
pd.DataFrame(result_q3)

# ========================================== Question4 ==========================================
### plot a bar chart showing the number of products per category computed in the previous question
result_q3.plot(x='product line', y='sum of sold products', kind='bar')
